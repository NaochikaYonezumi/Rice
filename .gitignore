# Phase 6 backups (DB dumps + volume archives, can be GB-scale)
backups/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Temp files
*.bak
*.bak[0-9]
*.tmp
.pr-body.json
.pr-response.json

# Claude Code local state (worktrees, sessions, etc.)
.claude/

# Playwright / GUI テストの実行成果物 (毎回再生成 / 絶対パスや
# スクリーンショットを含むためコミット禁止)
tests/gui/playwright-report/
tests/gui/test-results/
tests/gui/report/
tests/gui/visibility-check.png
tests/gui/*.png
tests/gui/.last-run.json
tests/gui/node_modules/

# Node dependencies (regenerated by `npm install`)
node_modules/

# Python bytecode (regenerated automatically)
__pycache__/
*.pyc
*.pyo

# ssh-agent コマンド誤入力で生まれる秘密鍵ファイル.
# `eval "$(ssh-agent -s)"` のリダイレクトミスで「eval "$(ssh-agent -s)"」という
# 名前のファイルが出来た事故があるため明示的に無視.
/eval *(ssh-agent *)*
/eval *ssh-agent*

# シェルコマンドのリダイレクトミスで生まれる残骸ファイル群.
# (例: docker-compose の "[内部]" 表記や curl 進捗の単語が
#  リダイレクト先のファイル名になってしまうケース)
/$COOKIE_JAR
/=
/CACHED
/CANCELED
/ERROR
/\[internal\]
/\[laravel
/\[rag-api
/reading
/transferring
