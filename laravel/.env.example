APP_NAME="RAG Web"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file

# RAG Python API
RAG_API_URL=http://rag-api:8000

# LLM設定 (ollama or claude)
LLM_PROVIDER=ollama

# Claude API (LLM_PROVIDER=claude の場合に設定)
ANTHROPIC_API_KEY=

OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# -----------------------------------------------
# メール送信（SMTP）
# -----------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mail.example.com        # SMTPサーバーホスト
MAIL_PORT=587                     # 587=STARTTLS / 465=SSL / 25=平文
MAIL_ENCRYPTION=tls               # tls / ssl / null
MAIL_USERNAME=user@example.com
MAIL_PASSWORD=your_password
MAIL_FROM_ADDRESS=user@example.com
MAIL_FROM_NAME="Mail RAG"

# -----------------------------------------------
# メール受信（IMAP / POP3）
# -----------------------------------------------
# プロトコル: imap または pop3
MAIL_INBOX_PROTOCOL=imap
# IMAP受信サーバー
MAIL_IMAP_HOST=mail.example.com
MAIL_IMAP_PORT=993               # 993=IMAPS / 143=STARTTLS
MAIL_IMAP_ENCRYPTION=ssl         # ssl / tls / null
MAIL_IMAP_USERNAME=user@example.com
MAIL_IMAP_PASSWORD=your_password
MAIL_IMAP_FOLDER=INBOX
# POP3受信サーバー（MAIL_INBOX_PROTOCOL=pop3 の場合）
MAIL_POP_HOST=mail.example.com
MAIL_POP_PORT=995                # 995=POP3S / 110=平文
MAIL_POP_ENCRYPTION=ssl          # ssl / null
MAIL_POP_USERNAME=user@example.com
MAIL_POP_PASSWORD=your_password
